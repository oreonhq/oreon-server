# GitHub App credentials (existing)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Build service connection (for RPM Build CI on rpm-specfiles PRs)
BUILD_SERVICE_URL=https://build.oreonhq.com
BUILD_SERVICE_USERNAME=admin
BUILD_SERVICE_PASSWORD=change-me-secure-password

# Optional: protect the /api/build-callback endpoint
CI_CALLBACK_SECRET=

# Optional: pre-set the GitHub App installation ID for oreonhq
# (skips the auto-detection in build-callback)
RPM_SPECSFILES_REPO_ID=
